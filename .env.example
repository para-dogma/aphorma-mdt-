# Database
DATABASE_URL=sqlite:///./aphorma_mdt.db

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Consensus
CONSENSUS_WINDOW_SECONDS=30
DEFAULT_HEALTH_FACTOR=1.0

# TON (optional)
TON_NETWORK=testnet
TON_ENDPOINT=https://testnet.toncenter.com/api/v2
TON_API_KEY=

# ============================================
# AphormA-MDT Environment Configuration
# ============================================
# NEVER commit .env file to git!
# Copy this file: cp .env.example .env
# ============================================

# Application
APP_NAME=aphorma-mdt
APP_VERSION=2.1.0
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# JWT Security (CHANGE THESE IN PRODUCTION!)
JWT_SECRET_KEY=change-me-to-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://user:password@db:5432/aphorma_mdt
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=change-me-redis-password

# TON Blockchain
TON_NETWORK=testnet
TON_ENDPOINT=https://testnet.toncenter.com/api/v2
TON_API_KEY=your-ton-api-key

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Security
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=60
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# SSL (for production)
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pemEOF

# 4.2 Создаём скрипт генерации безопасных секретов
cat > scripts/generate_secrets.sh << 'SCRIPT'
#!/bin/bash
# Generate secure secrets for AphormA-MDT

echo "🔐 Generating secure secrets..."

# JWT Secret (64 chars)
JWT_SECRET=$(openssl rand -hex 32)
echo "JWT_SECRET_KEY=$JWT_SECRET"

# Redis Password
REDIS_PASS=$(openssl rand -hex 16)
echo "REDIS_PASSWORD=$REDIS_PASS"

# Grafana Password
GRAFANA_PASS=$(openssl rand -hex 16)
echo "GRAFANA_ADMIN_PASSWORD=$GRAFANA_PASS"

echo ""
echo "⚠️  Save these to your .env file!"
echo "⚠️  NEVER commit .env to git!"
SCRIPT

chmod +x scripts/generate_secrets.sh

# 4.3 Создаём middleware для secret rotation
cat > aphorma_mdt/core/secret_rotation.py << 'EOF'
"""Secret rotation management"""
import os
import hashlib
from datetime import datetime
from typing import Optional
import redis

class SecretRotation:
    def __init__(self, redis_url: str = None):
        self.redis = redis.Redis.from_url(
            redis_url or os.getenv('REDIS_URL', 'redis://localhost:6379/0'),
            decode_responses=True
        )
        self.rotation_interval_days = 90
        self.last_rotation_key = 'secret:last_rotation'
    
    def get_secret(self, secret_name: str) -> str:
        """Get secret from environment with fallback"""
        # Сначала проверяем Redis (для rotated secrets)
        rotated = self.redis.get(f'secret:{secret_name}')        if rotated:
            return rotated
        
        # Fallback to environment
        return os.getenv(secret_name, '')
    
    def rotate_secret(self, secret_name: str, new_value: str) -> bool:
        """Rotate a secret"""
        try:
            # Сохраняем старый секрет с TTL 1 час (grace period)
            old_value = self.get_secret(secret_name)
            if old_value:
                self.redis.setex(
                    f'secret:old:{secret_name}',
                    3600,  # 1 hour grace period
                    old_value
                )
            
            # Устанавливаем новый секрет
            self.redis.set(f'secret:{secret_name}', new_value)
            
            # Логируем ротацию
            self.redis.lpush(
                'secret:rotation_log',
                f'{datetime.utcnow().isoformat()}:{secret_name}:rotated'
            )
            
            return True
        except Exception as e:
            print(f"Error rotating secret {secret_name}: {e}")
            return False
    
    def check_rotation_needed(self) -> bool:
        """Check if secrets need rotation"""
        last_rotation = self.redis.get(self.last_rotation_key)
        if not last_rotation:
            return True
        
        last_date = datetime.fromisoformat(last_rotation)
        days_since = (datetime.utcnow() - last_date).days
        return days_since >= self.rotation_interval_days
    
    def record_rotation(self):
        """Record that rotation was performed"""
        self.redis.set(
            self.last_rotation_key,
            datetime.utcnow().isoformat()
        )
    
    def get_rotation_status(self) -> dict:        """Get rotation status"""
        last_rotation = self.redis.get(self.last_rotation_key)
        needs_rotation = self.check_rotation_needed()
        
        return {
            'last_rotation': last_rotation,
            'needs_rotation': needs_rotation,
            'rotation_interval_days': self.rotation_interval_days,
            'active_secrets': len([k for k in self.redis.scan_iter(match='secret:*') if 'old:' not in k and 'rotation' not in k])
        }

secret_rotation = SecretRotation()
